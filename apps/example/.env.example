# Local client event log (EventStore)
DATABASE_URL=file:./local.db

# Remote sync server (Turso) — stores confirmed events from push/pull
# Falls back to DATABASE_URL, then file:./sync-server.db when unset
SYNC_DATABASE_URL=file:./sync-server.db

# Turso cloud example:
# SYNC_DATABASE_URL=libsql://<your-db>.<your-org>.turso.io
# SYNC_DATABASE_AUTH_TOKEN=<your-turso-auth-token>

# Optional: use Turso for the local client event log too
# DATABASE_URL=libsql://<your-db>.<your-org>.turso.io
# DATABASE_AUTH_TOKEN=<your-turso-auth-token>
