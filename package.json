{
  "name": "my-tanstack-db-collections",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "format": "vp fmt .",
    "format:fix": "vp fmt .",
    "check-types": "turbo run check-types",
    "quality": "turbo run //#lint //#format",
    "quality:fix": "turbo run //#lint:fix //#format:fix",
    "prepare": "vp config",
    "publish:event-sourced": "pnpm --filter @tanstack-db-collections/event-sourced publish --access public",
    "pack:event-sourced": "pnpm --filter @tanstack-db-collections/event-sourced exec npm pack --dry-run"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@tanstack/router-core": "1.169.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "esbuild": "^0.27.7",
      "postcss": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
